{
  "name": "world-of-promptcraft-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host=0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "three": "^0.170.0",
    "three-mesh-bvh": "^0.9.10"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
